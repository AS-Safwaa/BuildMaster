// ─────────────────────────────────────────────────────────
// Prisma Schema — SQLite for local dev
// Migration path to PostgreSQL: change provider to
// "postgresql" and update DATABASE_URL accordingly.
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("developer") // admin | developer
  createdAt DateTime @default(now()) @map("created_at")

  projects Project[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("draft") // draft | active | paused | completed | archived
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  creator User     @relation(fields: [createdBy], references: [id])
  configs Config[]

  @@map("projects")
}

model Config {
  id        String @id @default(cuid())
  key       String
  value     String
  projectId String @map("project_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("configs")
}
